<odoo>
  <record id="view_machine_status_tree" model="ir.ui.view">
    <field name="name">mrp.production.machine.status</field>
    <field name="model">mrp.production</field>
    <field name="arch" type="xml">
      <tree>
        <field name="repair_id"/>
        <field name="parent_product"/>
        <field name="sub_product"/>
        <field name="operation_name"/>
        <field name="workcenter_name"/>
        <field name="status"/>
        <field name="start_time"/>
        <field name="end_time"/>
        <field name="deviation_note"/>
      </tree>
    </field>
  </record>

  <menuitem id="menu_machine_status"
            name="Consulta por Máquina"
            parent="mrp.menu_mrp_root"
            action="action_machine_status"/>

  <record id="action_machine_status" model="ir.actions.act_window">
    <field name="name">Status por Máquina</field>
    <field name="res_model">mrp.production</field>
    <field name="view_mode">tree</field>
  </record>
</odoo>
