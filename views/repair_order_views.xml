<odoo>
    <!-- Sequência para OS (Garante que existe antes da view carregar) -->
    <record id="seq_repair_order_mrp" model="ir.sequence">
        <field name="name">Sequência Ordem de Reparo MRP</field>
        <field name="code">repair.order.seq</field>
        <field name="prefix">OS/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_repair_order_form_inherit_mrp_final" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.mrp.final</field>
        <field name="model">repair.order</field>
        <!-- Herda da view padrão do repair -->
        <field name="inherit_id" ref="repair.repair_order_form"/>
        <field name="arch" type="xml">
            
            <!-- 1. Adiciona campos no topo (após product_id ou partner_id) -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="os_number" readonly="1" force_save="1"/>
                <field name="deadline"/>
            </xpath>
            
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="equipment_description"/>
            </xpath>

            <!-- 2. Adiciona o Botão de Exportar no Header -->
            <!-- Inserimos após o último botão existente ou no final do header -->
            <xpath expr="//header" position="inside">
                <button name="action_export_report" 
                        type="object" 
                        string="Exportar Relatório Excel" 
                        class="btn-secondary" 
                        icon="fa-file-excel-o"
                        groups="base.group_user"/>
            </xpath>

            <!-- 3. Adiciona a Aba de Produções Vinculadas -->
            <xpath expr="//notebook" position="inside">
                <page string="Ordens de Produção (MOs)" name="productions_tab">
                    <group>
                        <group>
                            <field name="progress_percent" widget="progressbar"/>
                        </group>
                    </group>
                    <field name="production_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="parent_product"/>
                            <field name="operation_name"/>
                            <field name="workcenter_name"/>
                            <field name="status_custom" widget="badge" decoration-success="status_custom == 'done'" decoration-warning="status_custom == 'waiting'" decoration-info="status_custom == 'in_progress'" decoration-danger="status_custom == 'rejected'"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                        </tree>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name" readonly="1"/>
                                        <field name="product_id"/>
                                        <field name="parent_product"/>
                                        <field name="sub_product"/>
                                    </group>
                                    <group>
                                        <field name="operation_name"/>
                                        <field name="workcenter_name"/>
                                        <field name="status_custom"/>
                                        <field name="start_time"/>
                                        <field name="end_time"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="deviation_note"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
