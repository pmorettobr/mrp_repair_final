<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_repair_order_form_inherit" model="ir.ui.view">
    <field name="name">repair.order.form.inherit</field>
    <field name="model">repair.order</field>
    <field name="inherit_id" ref="repair.view_repair_order_form"/>
    <field name="arch" type="xml">
      
      <!-- Botão no header -->
      <xpath expr="//header" position="inside">
        <button name="action_export_report" 
                type="object" 
                string="Exportar Relatório Excel" 
                class="btn-primary"
                states="done"/>
      </xpath>
      
      <!-- Campos adicionais na sheet -->
      <xpath expr="//sheet/group[1]" position="after">
        <group>
          <field name="os_number"/>
          <field name="equipment_description"/>
          <field name="deadline"/>
          <field name="progress_percent" widget="progressbar"/>
        </group>
      </xpath>
      
      <!-- Notebook com abas adicionais -->
      <xpath expr="//notebook" position="inside">
        <page string="Componentes / Ordens de Produção">
          <field name="production_ids">
            <tree editable="bottom" default_order="id">
              <field name="parent_product"/>
              <field name="sub_product"/>
              <field name="operation_name"/>
              <field name="workcenter_name"/>
              <field name="status" widget="badge"/>
            </tree>
          </field>
        </page>
        <page string="Resumo">
          <group>
            <field name="progress_percent" widget="progressbar"/>
            <separator string="Estatísticas"/>
            <field name="production_ids" widget="kanban" nolabel="1"/>
          </group>
        </page>
      </xpath>
      
    </field>
  </record>
</odoo>
