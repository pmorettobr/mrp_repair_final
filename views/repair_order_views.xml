<odoo>
    <!-- 1. Sequência -->
    <record id="seq_repair_order_mrp" model="ir.sequence">
        <field name="name">Sequência Ordem de Reparo MRP</field>
        <field name="code">repair.order.seq</field>
        <field name="prefix">OS/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- 2. View Completa Minimalista (Foco nos seus campos) -->
    <record id="view_repair_order_form_complete_mrp" model="ir.ui.view">
        <field name="name">repair.order.form.complete.mrp</field>
        <field name="model">repair.order</field>
        <field name="priority" eval="99"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <form string="Ordem de Reparo">
                <header>
                    <!-- Apenas o SEU botão e o Status Bar. 
                         Os botões nativos (Confirmar, Iniciar, etc.) podem ser acionados 
                         pelo menu 'Ação' ou adicionaremos via herança segura depois que o módulo instalar. -->
                    <button name="action_export_report" type="object" string="Exportar Excel" class="btn-secondary" icon="fa-file-excel-o"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,under_repair,2binvoiced"/>
                </header>
                
                <sheet>
                    <!-- CRÍTICO: company_id invisível ANTES de qualquer coisa -->
                    <field name="company_id" groups="base.group_multi_company" invisible="1" force_save="1"/>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="partner_id" required="1"/>
                            <field name="partner_invoice_id"/>
                            <field name="partner_shipping_id"/>
                            <!-- Seus campos -->
                            <field name="os_number" readonly="1" force_save="1"/>
                            <field name="deadline"/>
                        </group>
                        <group>
                            <field name="product_id" required="1"/>
                            <field name="lot_id" domain="[('product_id', '=', product_id)]" groups="stock.group_production_lot"/>
                            <!-- Seu campo -->
                            <field name="equipment_description"/>
                            <field name="pricelist_id" groups="product.group_pricelist_item"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Aba Nativa de Serviços/Peças -->
                        <page string="Serviços e Peças" name="services_parts">
                            <field name="operations">
                                <tree editable="bottom">
                                    <field name="type"/>
                                    <field name="product_id" domain="[('type', 'in', ['product', 'consu'])]"/>
                                    <field name="name"/>
                                    <field name="product_uom" groups="uom.group_uom"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>

                        <!-- SUA NOVA ABA DE MOs -->
                        <page string="Ordens de Produção (MOs)" name="productions_tab">
                            <group>
                                <group>
                                    <field name="progress_percent" widget="progressbar"/>
                                </group>
                            </group>
                            <field name="production_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="parent_product"/>
                                    <field name="operation_name"/>
                                    <field name="workcenter_name"/>
                                    <field name="status_custom" widget="badge" decoration-success="status_custom == 'done'" decoration-warning="status_custom == 'waiting'" decoration-info="status_custom == 'in_progress'" decoration-danger="status_custom == 'rejected'"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <field name="company_id" invisible="1"/>
                                        <group>
                                            <group>
                                                <field name="name" readonly="1"/>
                                                <field name="product_id"/>
                                                <field name="parent_product"/>
                                                <field name="sub_product"/>
                                            </group>
                                            <group>
                                                <field name="operation_name"/>
                                                <field name="workcenter_name"/>
                                                <field name="status_custom"/>
                                                <field name="start_time"/>
                                                <field name="end_time"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="deviation_note"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        
                        <!-- Aba de Informações Adicionais -->
                        <page string="Informações Adicionais" name="other_infos">
                            <group>
                                <group>
                                    <field name="user_id"/>
                                    <field name="date_order"/>
                                </group>
                                <group>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    <field name="internal_notes"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. SEGUNDA VIEW: Herda da nossa view 'primary' apenas para adicionar os botões nativos com segurança -->
    <!-- Isso separa a definição estrutural (que precisa ser primary para o company_id) da adição de botões -->
    <record id="view_repair_order_form_buttons_mrp" model="ir.ui.view">
        <field name="name">repair.order.form.buttons.mrp</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="view_repair_order_form_complete_mrp"/>
        <field name="arch" type="xml">
            <!-- Adiciona botões nativos APENAS se existirem, usando try-catch implícito do XPath -->
            <!-- Se algum botão der erro, a view ainda carrega o resto. 
                 Nota: Se ainda der erro de 'action not valid', comente as linhas abaixo uma a uma até achar o culpado -->
            
            <xpath expr="//button[@name='action_export_report']" position="before">
                <button name="action_validate" states="draft" type="object" string="Confirmar Reparo" class="oe_highlight"/>
                <button name="action_repair_start" states="confirmed" type="object" string="Iniciar Reparo" class="oe_highlight"/>
                <button name="action_repair_end" states="under_repair" type="object" string="Finalizar Reparo" class="oe_highlight"/>
                <!-- Removemos o botão de fatura manual pois varia muito entre versões. O usuário pode usar o menu Ação > Criar Fatura -->
            </xpath>
        </field>
    </record>
</odoo>
