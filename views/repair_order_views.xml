<odoo>
    <!-- 1. Sequência -->
    <record id="seq_repair_order_mrp" model="ir.sequence">
        <field name="name">Sequência Ordem de Reparo MRP</field>
        <field name="code">repair.order.seq</field>
        <field name="prefix">OS/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- 2. Herança Mínima e Segura -->
    <record id="view_repair_order_form_minimal_mrp" model="ir.ui.view">
        <field name="name">repair.order.form.minimal.mrp</field>
        <field name="model">repair.order</field>
        <!-- Herdando da view correta que descobrimos no SQL -->
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            
            <!-- A. Injeta company_id invisível no sheet (resolve o erro de domínio do product_id) -->
            <xpath expr="//sheet" position="inside">
                <field name="company_id" groups="base.group_multi_company" invisible="1" force_save="1"/>
            </xpath>

            <!-- B. Adiciona APENAS o campo os_number após o partner_id (campo seguro que sabemos que existe) -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="os_number" readonly="1" force_save="1"/>
            </xpath>

        </field>
    </record>
</odoo>
