<odoo>
  <record id="view_repair_order_form_inherit" model="ir.ui.view">
    <field name="name">repair.order.form.inherit</field>
    <field name="model">repair.order</field>
    <field name="inherit_id" ref="repair.view_repair_order_form"/>
    <field name="arch" type="xml">
      <header position="inside">
        <button name="action_export_report" type="object" string="Exportar Relatório Excel" class="btn-primary"/>
      </header>
      <sheet position="inside">
        <group>
          <field name="os_number"/>
          <field name="equipment_description"/>
          <field name="deadline"/>
          <field name="progress_percent" widget="progressbar"/>
        </group>
        <notebook>
          <page string="Componentes / Ordens de Produção">
            <field name="production_ids">
              <tree editable="bottom">
                <field name="parent_product"/>
                <field name="sub_product"/>
                <field name="operation_name"/>
                <field name="workcenter_name"/>
                <field name="status"/>
              </tree>
            </field>
          </page>
          <page string="Resumo">
            <group>
              <field name="progress_percent" widget="progressbar"/>
            </group>
          </page>
        </notebook>
      </sheet>
    </field>
  </record>
</odoo>
